// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`
 
//database blueprint
//generator prisma client
generator client { 
//use prisma click generator
  provider = "prisma-client-js"

}
// db type = postgresql
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
enum OtpPurpose {
  REGISTER
  LOGIN
  FORGOT_PASSWORD
}
enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum UrlStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  DELETED
}

enum AuditAction {
  REGISTER
  LOGIN
  LOGOUT
  CREATE_URL
  UPDATE_URL
  DELETE_URL
  REDIRECT
  PASSWORD_RESET
}

model User {
  id                    Int        @id @default(autoincrement())
  name                  String
  email                 String     @unique
  password              String

  status                UserStatus @default(ACTIVE)
  isVerified            Boolean    @default(false)

  failedLoginAttempts   Int        @default(0)
  lockedUntil           DateTime?

  otps                  UserOtp[]
  urls                  Url[]
  refreshTokens         RefreshToken[]
  auditLogs             AuditLog[]

  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  deletedAt             DateTime?
}

model UserOtp {
  id           Int        @id @default(autoincrement())
  userId       Int
  otp          String
  purpose      OtpPurpose
  expiresAt    DateTime
  attemptCount Int        @default(0)
  isUsed       Boolean    @default(false)
  // kept for backwards compatibility with existing rows; mirrors isUsed
  verified     Boolean    @default(false)

  createdAt    DateTime   @default(now())

  user         User       @relation(fields: [userId], references: [id])

  @@index([userId, purpose, isUsed])
}

model Url {
  id          Int       @id @default(autoincrement())
  userId      Int

  originalUrl String
  shortCode   String    @unique
  customAlias String?   @unique

  totalClicks Int       @default(0)
  lastVisitedAt DateTime?

  status      UrlStatus @default(ACTIVE)
  expiresAt   DateTime?
  deletedAt   DateTime?

  visits      Visit[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@index([shortCode])
}
model Visit {
  id         Int      @id @default(autoincrement())

  urlId      Int

  ipAddress  String?
  browser    String?
  device     String?
  os         String?
  country    String?
  referrer   String?
  userAgent  String?

  visitedAt  DateTime @default(now())

  url        Url      @relation(fields: [urlId], references: [id])

  @@index([urlId, visitedAt])
}

model RefreshToken {
  id          Int       @id @default(autoincrement())
  userId      Int
  tokenHash   String    @unique
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id])

  @@index([userId])
}

model AuditLog {
  id         Int         @id @default(autoincrement())
  userId     Int?
  action     AuditAction
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime    @default(now())

  user       User?       @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}
